[40.0347, "o", "\r\n\u001b[?2004l\r"]
[40.038022, "o", "# Grazhda Configuration\r\r\n# This file is auto-generated during installation\r\r\n# Modify as needed for your environment\r\r\n\r\r\n# Dukh Web Server Configuration\r\r\ndukh:\r\r\n  host: localhost\r\r\n  port: 50501\r\r\n\r\r\n# Zgard Configuration\r\r\nzgard:\r\r\n  config: {}\r\r\n\r\r\ngeneral:\r\r\n  install_dir: /home/jake/.grazhda\r\r\n  sources_dir: /home/jake/.grazhda/sources\r\r\n  bin_dir: /home/jake/.grazhda/bin\r\r\n\r\r\nworkspaces:\r\r\n  - name: default\r\r\n    path: /home/jake/ws\r\r\n    clone_command_template: git clone --branch {{.Branch}} https://github.com/grazhda/{{.RepoName}} {{.DestDir}}\r\r\n    projects:\r\r\n      - name: ws-project1\r\r\n        branch: main\r\r\n        repositories:\r\r\n          - name: test-repo-1\r\r\n          - name: test-repo-2\r\r\n          - name: test-repo-1\r\r\n            local_dir_name: test-repo-1-copy\r\r\n          - name: test-repo-3\r\r\n            branch: dev\r\r\n      - name: ws-project2\r\r\n        branch: main\r\r\n        repositories:\r\r\n          - name: test-repo-1\r\r\n          - name: test-repo-2\r\r\n          - name: test-repo-3\r"]
[40.038478, "o", "\r\n  - name: secondary\r\r\n    path: /home/jake/secondary_ws\r\r\n    clone_command_template: git clone --branch {{.Branch}} https://github.com/grazhda/{{.RepoName}} {{.DestDir}}\r\r\n    projects:\r\r\n      - name: secondary-project1\r\r\n        branch: main\r\r\n        repositories:\r\r\n          - name: test-repo-1\r\r\n          - name: test-repo-2\r\r\n"]
