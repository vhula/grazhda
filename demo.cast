[12.02203, "o", "\u001b[0;32m║      Installation Successful!         ║\u001b[0m\r\n\u001b[0;32m╚═══════════════════════════════════════╝\u001b[0m\r\n\r\n\u001b[1;34mGrazhda installed to: /home/jake/.grazhda\u001b[0m\r\n\u001b[1;34mSources directory: /home/jake/.grazhda/sources\u001b[0m\r\n\u001b[1;34mBinaries: /home/jake/.grazhda/bin\u001b[0m\r\n\u001b[1;34mConfiguration: /home/jake/.grazhda/config.yaml\u001b[0m\r\n\r\nTo get started:\r\n  \u001b[1;33msource \"/home/jake/.grazhda/bin/grazhda-init.sh\"\u001b[0m\r\n\r\nFor more information, visit:\r\n  https://github.com/vhula/grazhda\r\n\r\n"]
