[67.943025, "o", "\r\n\u001b[?2004l\r"]
[67.949915, "o", "Manage workspace lifecycle: initialize, purge, or pull repositories.\r\n\r\nUsage:\r\n  zgard ws [command]\r\n\r\nAvailable Commands:\r\n  init        Initialize a workspace by cloning all repositories\r\n  pull        Pull latest changes for all repositories in a workspace\r\n  purge       Purge a workspace by removing all cloned repositories\r\n  status      Show workspace health as monitored by dukh\r\n\r\nFlags:\r\n  -h, --help   help for ws\r\n\r\nUse \"zgard ws [command] --help\" for more information about a command.\r\n"]
[67.951347, "o", "\u001b[?2004h\u001b]0;jake@Zenbook: ~\u0007\u001b[01;32mjake@Zenbook\u001b[00m:\u001b[01;34m~\u001b[00m$ "]
