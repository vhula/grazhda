[35.409746, "o", "\u001b[1;1H\u001b[34m# Grazhda Configuration\r\n# This file is auto-generated during installation\u001b[m\u001b[2;50H\u001b[K\u001b[3;1H\u001b[34m# Modify as needed for your environment\u001b[m\u001b[3;40H\u001b[K\u001b[5;1H\u001b[34m# Editor used by `grazhda config --edit`.\r\n# Resolved in order: this field →\u001b[6;34H $VISUAL →\u001b[6;44H $EDITOR →\u001b[6;54H vi\u001b[m\r\n\u001b[36meditor\u001b[m\u001b[35m:\u001b[m vim\r\n\r\n\u001b[34m# Dukh gRPC Server Configuration\u001b[m\r\n\u001b[36mdukh\u001b[m\u001b[35m:\u001b[m\r\n  \u001b[36mhost\u001b[m\u001b[35m:\u001b[m localhost\r\n  \u001b[36mport\u001b[m\u001b[35m:\u001b[m \u001b[31m50501\u001b[m\r\n  \u001b[36mmonitoring\u001b[m\u001b[35m:\u001b[m\r\n    \u001b[36mperiod_mins\u001b[m\u001b[35m:\u001b[m \u001b[31m5\u001b[m\r\n\r\n\u001b[34m# Zgard Configuration\u001b[m\r\n\u001b[36mzgard\u001b[m\u001b[35m:\u001b[m\r\n  \u001b[36mconfig\u001b[m\u001b[35m:\u001b[m \u001b[35m{}\u001b[m\r\n\r\n\u001b[36mgeneral\u001b[m\u001b[35m:\u001b[m\r\n  \u001b[36minstall_dir\u001b[m\u001b[35m:\u001b[m /home/jake/.grazhda\r\n  \u001b[36msources_dir\u001b[m\u001b[35m:\u001b[m /home/jake/.grazhda/sources\r\n  \u001b[36mbin_dir\u001b[m\u001b[35m:\u001b[m /home/jake/.grazhda/bin\r\n\r\n\u001b[36mworkspaces\u001b[m\u001b[35m:\u001b[m\r\n  \u001b[38;5;130m- \u001b[m\u001b[36mname\u001b[m\u001b[35m:\u001b[m default\r\n    \u001b[36mpath\u001b[m\u001b[35m:\u001b[m ~/ws\r\n    \u001b[36mdefault\u001b[m\u001b[35m:\u001b[m \u001b[31mtrue\u001b[m\r\n    \u001b[36mclone_command_template\u001b[m"]
[35.410149, "o", "\u001b[35m:\u001b[m git clone --branch \u001b[35m{{\u001b[m.Branch\u001b[35m}}\u001b[m https://github.com/grazhda/{{.RepoName}} \u001b[35m{{\u001b[m.DestDir\u001b[35m}}\u001b[m\r\n   \u001b[34m # structure controls how repository names containing \"/\" are mapped to local\r\n\u001b[m   \u001b[34m # directories inside each project folder.\r\n\u001b[m   \u001b[34m #   tree (default) —\u001b[32;25H preserves full path:  org/pack/repo →\u001b[32;63H <project>/org/pack/repo\r\n\u001b[m   \u001b[34m #   list           —\u001b[33;25H uses last URL segment: org/pack/repo →\u001b[33;64H <project>/repo\r\n\u001b[m   \u001b[34m #                    (.git suffix is stripped; use local_dir_name to resolve conflicts)\u001b[m\r\n    \u001b[36mstructure\u001b[m\u001b[35m:\u001b[m tree\r\n    \u001b[36mprojects\u001b[m\u001b[35m:\u001b[m\u001b[37;7H\u001b[38;5;130m- \u001b[m\u001b[36mname\u001b[m\u001b[35m:\u001b[m ws-project1\u001b[38;9H\u001b[36mbranch\u001b[m\u001b[35m:\u001b[m main\u001b[39;9H\u001b[36mrepositories\u001b[m\u001b[35m:\u001b[m\u001b[40;11H\u001b[38;5;130m- \u001b[m\u001b[36mname\u001b[m\u001b[35m:\u001b[m test-repo-1\u001b[41;11H\u001b[38;5;130m- \u001b[m\u001b[36mname\u001b[m\u001b[35m:\u001b[m test-repo-2\u001b[42;11H\u001b[38;5;130m- \u001b[m\u001b[36mname\u001b[m\u001b[35m:"]
[35.415677, "o", "\u001b[m test-repo-1\u001b[43;13H\u001b[36mlocal_dir_name\u001b[m\u001b[35m:\u001b[m test-repo-1-copy\u001b[44;11H\u001b[38;5;130m- \u001b[m\u001b[36mname\u001b[m\u001b[35m:\u001b[m test-repo-3\u001b[45;13H\u001b[36mbranch\u001b[m\u001b[35m:\u001b[m dev\u001b[46;7H\u001b[38;5;130m- \u001b[m\u001b[36mname\u001b[m\u001b[35m:\u001b[m ws-project2\u001b[47;9H\u001b[36mbranch\u001b[m\u001b[35m:\u001b[m main\u001b[48;116H1,1\u001b[11CTop\u001b[1;1H\u001b[?25h\u001b[?12$p\u001b[?25l\u001b[48;106H/\u001b[1;1H\u001b[48;107H0\u001b[1;1H\u001b[48;108Ha\u001b[1;1H\u001b[48;109H0\u001b[1;1H\u001b[48;110Ha\u001b[1;1H\u001b[48;111H/\u001b[1;1H\u001b[48;112H2\u001b[1;1H\u001b[48;113H4\u001b[1;1H\u001b[48;114H2\u001b[1;1H\u001b[48;115H4\u001b[1;1H"]
[35.435177, "o", "\u001b[48;106H          \u001b[1;1H\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[1;1H\u001b[96m# Grazhda Configuration\r\n# This file is auto-generated during installation\r\n# Modify as needed for your environment\r\n\r\n# Editor used by `grazhda config --edit`.\r\n# Resolved in order: this field →\u001b[6;34H $VISUAL →\u001b[6;44H $EDITOR →\u001b[6;54H vi\u001b[m\r\n\u001b[1m\u001b[96meditor\u001b[m\u001b[38;5;224m:\u001b[m vim\r\n\r\n\u001b[96m# Dukh gRPC Server Configuration\u001b[m\r\n\u001b[1m\u001b[96mdukh\u001b[m\u001b[38;5;224m:\u001b[m\r\n  \u001b[1m\u001b[96mhost\u001b[m\u001b[38;5;224m:\u001b[m localhost\r\n  \u001b[1m\u001b[96mport\u001b[m\u001b[38;5;224m:\u001b[m \u001b[95m50501\u001b[m\r\n  \u001b[1m\u001b[96mmonitoring\u001b[m\u001b[38;5;224m:\u001b[m\r\n    \u001b[1m\u001b[96mperiod_mins\u001b[m\u001b[38;5;224m:\u001b[m \u001b[95m5\u001b[m\r\n\r\n\u001b[96m# Zgard Configuration\u001b[m\r\n\u001b[1m\u001b[96mzgard\u001b[m\u001b[38;5;224m:\u001b[m\r\n  \u001b[1m\u001b[96mconfig\u001b[m\u001b[38;5;224m:\u001b[m \u001b[38;5;224m{}\u001b[m\r\n\r\n\u001b[1m\u001b[96mgeneral\u001b[m\u001b[38;5;224m:\u001b[m\r\n  \u001b[1m\u001b[96minstall_dir\u001b[m\u001b[38;5;224m:\u001b[m /home/jake/.grazhda\r\n  \u001b[1m\u001b[96msources_dir\u001b[m\u001b[38;5;224m:\u001b[m /home/jake/.grazhda/sources\r\n  \u001b[1m\u001b[96mbin_dir\u001b[m\u001b[38;5;224m:\u001b[m /home/jake/.grazhda/bin\r\n\r\n\u001b[1m\u001b[96mworkspaces\u001b[m\u001b[38;5;224m:\u001b[m\r\n  \u001b[93m- \u001b[m\u001b["]
